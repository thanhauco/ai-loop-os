# API
PORT=4000
DATA_DIR=.data
# Optional PostgreSQL mirror for production persistence/audit queries.
DATABASE_URL=postgresql://ai_loop_os:ai_loop_os_dev@localhost:5432/ai_loop_os

# Optional graph/vector services for future memory adapters.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ai-loop-os-dev
QDRANT_URL=http://localhost:6333

# Gateway
GATEWAY_PORT=4100
API_BASE_URL=http://localhost:4000

# Worker
WORKER_POLL_INTERVAL_MS=5000

# Approval RBAC
# If set, approval/rejection endpoints require Authorization: Bearer <token>
OPERATOR_TOKEN=

# Model provider
# mock | openai-compatible
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=

# --- NVIDIA Build (build.nvidia.com, OpenAI-compatible) — cloud model glm5.2 ---
# Set LLM_PROVIDER=openai-compatible, LLM_BASE_URL=https://integrate.api.nvidia.com/v1,
# LLM_MODEL=z-ai/glm-5.2, LLM_API_KEY=<your nvapi- key>.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=z-ai/glm-5.2
