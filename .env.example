# API
PORT=4000
DATA_DIR=.data
# Optional PostgreSQL mirror for production persistence/audit queries.
DATABASE_URL=

# Gateway
GATEWAY_PORT=4100
API_BASE_URL=http://localhost:4000

# Worker
WORKER_POLL_INTERVAL_MS=5000

# Approval RBAC
# If set, approval/rejection endpoints require Authorization: Bearer <token>
OPERATOR_TOKEN=

# Model provider
# mock | openai-compatible
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=
