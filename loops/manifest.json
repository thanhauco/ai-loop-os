{
  "version": "0.1.0",
  "executionOrder": [
    "planner",
    "routing",
    "research",
    "tool_selection",
    "coding",
    "evaluation",
    "critic",
    "verification",
    "simulation",
    "reflection",
    "retry",
    "security",
    "compliance",
    "cost",
    "latency",
    "multi_agent_debate",
    "human_approval",
    "knowledge_graph",
    "learning",
    "memory",
    "deployment",
    "monitoring"
  ],
  "loops": {
    "planner": { "ownerAgent": "planner_agent", "qualityGate": "tasks.length > 0" },
    "routing": { "ownerAgent": "architect_agent", "qualityGate": "selectedModel exists" },
    "research": { "ownerAgent": "researcher_agent", "qualityGate": "facts.length > 0" },
    "tool_selection": { "ownerAgent": "planner_agent", "qualityGate": "selectedTools.length > 0" },
    "coding": { "ownerAgent": "coder_agent", "qualityGate": "filePlan.length > 0" },
    "evaluation": { "ownerAgent": "reviewer_agent", "qualityGate": "quality >= 85" },
    "critic": { "ownerAgent": "reviewer_agent", "qualityGate": "challenges.length > 0" },
    "verification": { "ownerAgent": "qa_agent", "qualityGate": "all checks passed" },
    "simulation": { "ownerAgent": "architect_agent", "qualityGate": "scenarios.length > 0" },
    "reflection": { "ownerAgent": "architect_agent", "qualityGate": "rootCause documented" },
    "retry": { "ownerAgent": "planner_agent", "qualityGate": "strategy selected" },
    "security": { "ownerAgent": "security_agent", "qualityGate": "no critical findings" },
    "compliance": { "ownerAgent": "compliance_agent", "qualityGate": "evidence generated" },
    "cost": { "ownerAgent": "planner_agent", "qualityGate": "budgetStatus within-budget or approved" },
    "latency": { "ownerAgent": "qa_agent", "qualityGate": "status within-budget" },
    "multi_agent_debate": { "ownerAgent": "architect_agent", "qualityGate": "consensus documented" },
    "human_approval": { "ownerAgent": "compliance_agent", "qualityGate": "approved or not_required" },
    "knowledge_graph": { "ownerAgent": "architect_agent", "qualityGate": "relationships.length > 0" },
    "learning": { "ownerAgent": "architect_agent", "qualityGate": "workflowImprovements.length > 0" },
    "memory": { "ownerAgent": "architect_agent", "qualityGate": "records written" },
    "deployment": { "ownerAgent": "deployment_agent", "qualityGate": "rollback plan exists" },
    "monitoring": { "ownerAgent": "qa_agent", "qualityGate": "metrics emitted" }
  }
}
